{
    "name": "oi-lab/oi-laravel-insee",
    "description": "Laravel package for INSEE SIRENE API integration",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "OI Lab",
            "email": "contact@oi-lab.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/cache": "^11.0|^12.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "orchestra/testbench": "^9.0|^10.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "OiLab\\OiLaravelInsee\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OiLab\\OiLaravelInsee\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OiLab\\OiLaravelInsee\\OiLaravelInseeServiceProvider"
            ],
            "aliases": {
                "Insee": "OiLab\\OiLaravelInsee\\Facades\\Insee"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
